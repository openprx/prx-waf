# prx-waf environment configuration example.
# Copy to `.env` and fill in real values before running docker-compose.
#
# JWT_SECRET signs admin API access tokens. It MUST be:
#   - at least 32 characters long
#   - unique and randomly generated (not a placeholder)
#   - kept secret
# The server refuses to start if this is weak, empty, or a known placeholder.
#
# Generate a strong value, e.g.:
#   openssl rand -base64 48
JWT_SECRET=

# Optional: initial admin password. If unset, a random one is generated and
# printed once to stdout on first startup.
# ADMIN_PASSWORD=

# Optional: log level (error|warn|info|debug|trace)
RUST_LOG=info
